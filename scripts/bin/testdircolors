#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"

DIRCOLORS_FILE="${1:-${DOTFILES_DIR}/dircolors/.dircolors}"
TEST_DIR="${2:-${DOTFILES_DIR}/ls_test}"

if [ ! -f "${DIRCOLORS_FILE}" ]; then
  echo "Missing dircolors file: ${DIRCOLORS_FILE}" >&2
  exit 1
fi

if [ ! -d "${TEST_DIR}" ]; then
  echo "Missing ls_test directory: ${TEST_DIR}" >&2
  exit 1
fi

if command -v gdircolors >/dev/null 2>&1; then
  DC=gdircolors
elif command -v dircolors >/dev/null 2>&1; then
  DC=dircolors
else
  echo "No dircolors implementation found (gdircolors/dircolors)." >&2
  exit 1
fi

if command -v gls >/dev/null 2>&1; then
  LS=gls
  COLOR_FLAG="--color=always"
elif ls --color=always -d . >/dev/null 2>&1; then
  LS=ls
  COLOR_FLAG="--color=always"
else
  LS=ls
  COLOR_FLAG="-G"
fi

eval "$(${DC} -b "${DIRCOLORS_FILE}")"

echo "Using dircolors: ${DC}"
echo "Using ls: ${LS} ${COLOR_FLAG}"
echo "Dircolors file: ${DIRCOLORS_FILE}"
echo "Test directory: ${TEST_DIR}"
echo

section() {
  echo "=== $1 ==="
}

section "Types and Permissions"
${LS} ${COLOR_FLAG} -lad "${TEST_DIR}/types"/* 2>/dev/null || true
echo

section "Wildcard Pattern Cases"
find "${TEST_DIR}/patterns" -mindepth 1 -maxdepth 1 -type d | sort | head -20 | while read -r d; do
  ${LS} ${COLOR_FLAG} -lad "${d}"/* 2>/dev/null || true
done
echo

section "Extension Cases"
find "${TEST_DIR}/extensions" -mindepth 1 -maxdepth 1 -type d | sort | head -40 | while read -r d; do
  ${LS} ${COLOR_FLAG} -lad "${d}"/* 2>/dev/null || true
done
echo

echo "Preview limited to first 20 pattern folders and first 40 extension folders."
echo "To inspect everything:"
echo "  ${LS} ${COLOR_FLAG} -laR ${TEST_DIR}"