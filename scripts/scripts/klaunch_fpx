#! /bin/zsh

kitten @ launch --keep-focus --type tab --tab-title "fleetplan" --title "fleetplan_docker" --hold --copy-env --cwd ~/Sites/fleetplan
kitten @ send-text --match "title:^fleetplan_docker" "npm run dev \n"

kitten @ goto-layout --match "title:^fleetplan" grid

