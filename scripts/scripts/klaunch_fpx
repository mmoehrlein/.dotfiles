kitten @ send-text --match "title:^fleetplanX_watch" "fnm exec --using .nvmrc yarn run watch \n"

kitten @ launch --keep-focus --match "title:^fleetplan" --title "fleetplanX_fp_api" --hold --copy-env --cwd ~/Sites/fleetplanX/fp-api
kitten @ send-text --match "title:^fleetplanX_fp_api" "fnm exec --using ../.nvmrc yarn run dev \n"

kitten @ launch --match "title:^fleetplan" --title "fleetplanX_fp_gen" --hold --copy-env --cwd ~/Sites/fleetplanX/fp-gen
kitten @ send-text --match "title:^fleetplanX_fp_gen" "fnm exec --using ../.nvmrc yarn run specs-watch \n"

